{
  "name": "kryptonbrowser",
  "version": "1.0.0",
  "description": "KryptonBrowser — A Post-Quantum Cryptography enabled secure browser",
  "main": "src/main/main.js",
  "scripts": {
    "start": "npm run build:ui && electron .",
    "build:ui": "vite build",
    "build": "npm run build:ui && electron-builder build --mac",
    "build:dir": "npm run build:native && npm run build:ui && electron-builder build --mac --dir",
    "build:linux": "npm run build:native && npm run build:ui && electron-builder build --linux",
    "build:dir:linux": "npm run build:native && npm run build:ui && electron-builder build --linux --dir",
    "build:native": "cd native && cmake-js compile -T krypton_pqc_addon",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest tests/unit",
    "test:e2e": "playwright test",
    "lint": "eslint \"src/**/*.js\"",
    "format": "prettier --write \"src/**/*.{js,html,css}\"",
    "prepare": "cd .. && husky electron-app/.husky"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{html,css}": [
      "prettier --write"
    ]
  },
  "author": "KryptonBrowser Team",
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "com.krypton.browser",
    "productName": "KryptonBrowser",
    "publish": [
      "github"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "files": [
      "src/main/main.js",
      "src/main/preload.js",
      "src/main/preload-webview.js",
      "src/main/pqc-engine.js",
      "blocklist.json",
      "build/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "@noble/post-quantum": "^0.6.1",
    "cmake-js": "^7.3.0",
    "dompurify": "^3.4.10",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "node-addon-api": "^8.0.0"
  }
}
